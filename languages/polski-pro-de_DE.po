#. Plugin Name of the plugin
#: polski.php src/Admin/DeactivationHandler.php:58
msgid "Polski for WooCommerce"
msgstr "Polski für WooCommerce"

#. Plugin URI of the plugin
#: polski.php
msgid "https://wppoland.com/pl/polski/"
msgstr "https://wppoland.com/pl/polski/"

#. Description of the plugin
#: polski.php
msgid ""
"Adapts WooCommerce and WordPress to Polish market requirements: GPSR, "
"Omnibus, GDPR, unit prices, withdrawal forms, and storefront tools."
msgstr ""
"Passt WooCommerce und WordPress an die Anforderungen des polnischen Marktes "
"an: GPSR, Omnibus, DSGVO, Einzelpreise, Widerrufsformulare und Storefront-"
"Tools."

#. Author of the plugin
#: polski.php
msgid "WPPoland"
msgstr "WPPoland"

#. Author URI of the plugin
#: polski.php
msgid "https://wppoland.com"
msgstr "https://wppoland.com"

#: config/defaults.php:18
msgid "Platforma ODR: https://ec.europa.eu/consumers/odr"
msgstr "OS-Plattform: https://ec.europa.eu/consumers/odr"

#: config/defaults.php:19
msgid ""
"Gotowe! Wygenerowaliśmy dla Ciebie wstępne szkice stron prawnych. Przejrzyj "
"je, dostosuj do swoich potrzeb i śmiało opublikuj."
msgstr ""
"Bereit! Wir haben für dich erste Entwürfe juristischer Seiten erstellt. "
"Überprüfe sie, passe sie an deine Bedürfnisse an und veröffentliche sie."

#: config/defaults.php:20
msgid "Moduły zapisane."
msgstr "Module gespeichert."

#: config/defaults.php:21
msgid "Skonfiguruj Polski dla Twojego sklepu"
msgstr "Konfiguriere Polski für deinen Shop"

#: config/defaults.php:22
msgid ""
"Jeszcze chwila i sklep będzie gotowy. Przejrzyj moduły, ustaw strony prawne "
"i domknij konfigurację w panelu Polski."
msgstr ""
"Nur einen Moment und der Laden ist fertig. Durchsuche die Module, lege "
"rechtliche Seiten fest und schließe die Konfiguration im polnischen Bereich "
"ab."

#: config/defaults.php:23
msgid "Otwórz konfigurację Polski"
msgstr "Öffne die Polen-Konfiguration"

#: config/defaults.php:24
msgid "Aktywna"
msgstr "Aktiv"

#: config/defaults.php:25
msgid "Wyłączona"
msgstr "Deaktiviert"

#: config/defaults.php:26
msgid "Nieskonfigurowany"
msgstr "Nicht konfiguriert"

#: config/defaults.php:27 config/defaults.php:33
msgid "Strony prawne"
msgstr "Rechtliche Seiten"

#: config/defaults.php:28
msgid "Masz już za sobą {done} z {total} kroków. Znakomicie!"
msgstr ""
"Du hast bereits {done} von {total} Schritten abgeschlossen. Exzellent!"

#: config/defaults.php:29
msgid "Wyświetlanie podatku"
msgstr "Steueranzeige"

#: config/defaults.php:30
msgid "Zwolnienie podmiotowe (art. 113)"
msgstr "Subjektive Befreiung (Artikel 113)"

#: config/defaults.php:31
msgid "Standardowy VAT"
msgstr "Standard-Mehrwertsteuer"

#: config/defaults.php:32
msgid "Podwójna weryfikacja (DOI)"
msgstr "Doppelte Verifizierung (DOI)"

#: config/defaults.php:34
msgid "Strona"
msgstr "Seite"

#: config/defaults.php:35 config/defaults.php:162 config/defaults.php:259
