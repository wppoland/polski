#: config/defaults.php:169 config/defaults.php:197
#: templates/emails/double-opt-in.php:23
#: templates/emails/plain/double-opt-in.php:20
msgid "Cześć {name},"
msgstr "Hallo {name},"

#: config/defaults.php:170
