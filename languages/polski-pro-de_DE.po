msgid "Frequently Bought Together"
msgstr "Häufig zusammen gekauft"

#: src/Admin/ModulesPage.php:1281
msgid ""
"Amazon-style \"frequently bought together\" recommendations with bundled "
"discount."
msgstr ""
"„Häufig zusammen gekauft“-Empfehlungen im Amazon-Stil mit gebündeltem "
"Rabatt."

