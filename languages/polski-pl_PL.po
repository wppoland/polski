#: src/Service/RodoTrainingDocsService.php:188
msgid "Purpose limitation"
msgstr "Ograniczenie celu"

#: src/Service/RodoTrainingDocsService.php:189
msgid "Data minimisation"
msgstr "Minimalizacja danych"

#: src/Service/RodoTrainingDocsService.php:190
msgid "Accuracy"
msgstr "Prawidłowość"

#: src/Service/RodoTrainingDocsService.php:191
msgid "Storage limitation"
msgstr "Ograniczenie przechowywania"

#: src/Service/RodoTrainingDocsService.php:192
