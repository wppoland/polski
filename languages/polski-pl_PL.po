#: src/PageCompliance/Rules/AccessibilityRules.php:30
msgid "Document language declared (html lang)"
msgstr "Zadeklarowany język dokumentu (html lang)"

#: src/PageCompliance/Rules/AccessibilityRules.php:42
msgid "Add a `lang` attribute to the <html> element (WCAG 3.1.1). WordPress usually emits this via the language_attributes() call."
msgstr "Dodaj atrybut `lang` do elementu <html> (WCAG 3.1.1). WordPress zazwyczaj generuje go przez wywołanie language_attributes()."

#: src/PageCompliance/Rules/AccessibilityRules.php:46
msgid "Skip-to-content link present"
msgstr "Obecny link przeskakujący do treści"

#: src/PageCompliance/Rules/AccessibilityRules.php:55
msgid "Provide a skip-to-content link as the first focusable element (WCAG 2.4.1)."
msgstr "Udostępnij link przeskakujący do treści jako pierwszy element, na który można ustawić fokus (WCAG 2.4.1)."

#: src/PageCompliance/Rules/AccessibilityRules.php:59
msgid "Primary heading (h1) present"
msgstr "Obecny główny nagłówek (h1)"

#: src/PageCompliance/Rules/AccessibilityRules.php:64
msgid "Homepage should expose exactly one <h1> describing the page (WCAG 1.3.1 / 2.4.6)."
msgstr "Strona główna powinna zawierać dokładnie jeden <h1> opisujący stronę (WCAG 1.3.1 / 2.4.6)."

#: src/PageCompliance/Rules/AccessibilityRules.php:68
msgid "Responsive viewport declared"
msgstr "Zadeklarowany responsywny viewport"

#: src/PageCompliance/Rules/AccessibilityRules.php:74
msgid "Include <meta name=\"viewport\"> with width=device-width so the page scales on mobile (WCAG 1.4.10 Reflow)."
msgstr "Dodaj <meta name=\"viewport\"> z width=device-width, aby strona skalowała się na urządzeniach mobilnych (WCAG 1.4.10 Reflow)."

#: src/PageCompliance/Rules/AccessibilityRules.php:78
msgid "Search form uses role=\"search\" or <search>"
msgstr "Formularz wyszukiwania używa role=\"search\" lub <search>"

#: src/PageCompliance/Rules/AccessibilityRules.php:85
msgid "If your header exposes a search form, wrap it in <search> or add role=\"search\" so assistive tech can jump to it."
msgstr "Jeśli w nagłówku znajduje się formularz wyszukiwania, opakuj go w <search> lub dodaj role=\"search\", aby technologie wspomagające mogły do niego przejść."

#: src/PageCompliance/Rules/AccessibilityRules.php:89
msgid "Main landmark defined"
msgstr "Zdefiniowany obszar główny (main)"

#: src/PageCompliance/Rules/AccessibilityRules.php:98
msgid "The primary content should be wrapped in <main> or role=\"main\" (WCAG 1.3.1)."
msgstr "Główna treść powinna być opakowana w <main> lub role=\"main\" (WCAG 1.3.1)."

#: src/PageCompliance/Rules/AccessibilityRules.php:102
msgid "Focus outline not suppressed globally"
msgstr "Obramowanie fokusa nie jest globalnie wyłączone"

#: src/PageCompliance/Rules/AccessibilityRules.php:110
msgid "Global `outline: none` on :focus breaks keyboard visibility (WCAG 2.4.7). Replace with a visible focus-visible ring."
msgstr "Globalne `outline: none` na :focus psuje widoczność nawigacji klawiaturą (WCAG 2.4.7). Zastąp widocznym pierścieniem focus-visible."

#: src/PageCompliance/Rules/AccessibilityRules.php:114
msgid "No autoplay video with sound"
msgstr "Brak automatycznego odtwarzania wideo z dźwiękiem"

#: src/PageCompliance/Rules/AccessibilityRules.php:120
msgid "Avoid autoplay (WCAG 1.4.2 Audio Control) or ensure the video is muted and stops within 5 seconds."
msgstr "Unikaj automatycznego odtwarzania (WCAG 1.4.2 Audio Control) lub upewnij się, że wideo jest wyciszone i zatrzymuje się w ciągu 5 sekund."

#: src/PageCompliance/Rules/AccessibilityRules.php:124
msgid "Images missing alt attribute (heuristic)"
msgstr "Obrazy bez atrybutu alt (heurystyka)"

#: src/PageCompliance/Rules/AccessibilityRules.php:129
msgid "The homepage contains <img> tags that did not have an `alt=` attribute in the sampled markup (WCAG 1.1.1)."
msgstr "Strona główna zawiera tagi <img>, które nie miały atrybutu `alt=` w analizowanym kodzie (WCAG 1.1.1)."

#: src/PageCompliance/Rules/CookieBannerRules.php:31
msgid "Cookie banner present in HTML"
msgstr "Baner cookie obecny w HTML"

#: src/PageCompliance/Rules/CookieBannerRules.php:38
msgid "No cookie-related markup was detected on the homepage. Install a banner or ensure it renders on initial load (not only after client-side JS)."
msgstr "Nie wykryto znaczników związanych z cookie na stronie głównej. Zainstaluj baner lub upewnij się, że renderuje się przy pierwszym załadowaniu (nie tylko po uruchomieniu JS po stronie klienta)."

#: src/PageCompliance/Rules/CookieBannerRules.php:42
msgid "Accept button label"
msgstr "Etykieta przycisku Akceptuję"

#: src/PageCompliance/Rules/CookieBannerRules.php:54
msgid "Expose a clearly labelled Accept / Akceptuje button in the banner."
msgstr "Wyświetl w banerze wyraźnie oznaczony przycisk Akceptuję."

#: src/PageCompliance/Rules/CookieBannerRules.php:58
msgid "Reject button with equal prominence"
msgstr "Przycisk Odrzuć o równej widoczności"

#: src/PageCompliance/Rules/CookieBannerRules.php:71
msgid "Active consent requires an equally visible Reject option next to Accept. A greyed-out or hidden button is not compliant."
msgstr "Aktywna zgoda wymaga równie widocznej opcji Odrzuć obok Akceptuję. Wyszarzony lub ukryty przycisk nie spełnia wymagań."

#: src/PageCompliance/Rules/CookieBannerRules.php:75
msgid "Granular settings / preferences"
msgstr "Szczegółowe ustawienia / preferencje"

#: src/PageCompliance/Rules/CookieBannerRules.php:87
msgid "Provide a Settings / Preferences link so users can consent to individual categories (analytics, marketing) independently."
msgstr "Udostępnij link Ustawienia / Preferencje, aby użytkownicy mogli niezależnie wyrażać zgodę na poszczególne kategorie (analityka, marketing)."

#: src/PageCompliance/Rules/CookieBannerRules.php:91
msgid "Analytics category mentioned"
msgstr "Wymieniona kategoria Analityka"

#: src/PageCompliance/Rules/CookieBannerRules.php:100
msgid "Explicitly name the Analytics/Statistics category so the user knows what the toggle covers."
msgstr "Wyraźnie nazwij kategorię Analityka/Statystyki, aby użytkownik wiedział, co obejmuje przełącznik."

#: src/PageCompliance/Rules/CookieBannerRules.php:104
msgid "Marketing / advertising category mentioned"
msgstr "Wymieniona kategoria Marketing / reklama"

#: src/PageCompliance/Rules/CookieBannerRules.php:114
msgid "Name the Marketing/Advertising category separately so opt-in is granular."
msgstr "Nazwij kategorię Marketing/Reklama osobno, aby zgoda była szczegółowa."

#: src/PageCompliance/Rules/CookieBannerRules.php:118
msgid "Link to privacy policy in banner area"
msgstr "Link do polityki prywatności w obszarze banera"

#: src/PageCompliance/Rules/CookieBannerRules.php:126
msgid "Link the banner to the full privacy policy so users can read the details before consenting."
msgstr "Dodaj w banerze link do pełnej polityki prywatności, aby użytkownicy mogli zapoznać się ze szczegółami przed wyrażeniem zgody."

#: src/PageCompliance/Rules/CookieBannerRules.php:130
msgid "Consent withdrawal mechanism hinted"
msgstr "Wskazany mechanizm wycofania zgody"

#: src/PageCompliance/Rules/CookieBannerRules.php:141
msgid "Mention that consent can be withdrawn or changed at any time from the banner or a dedicated link."
msgstr "Wspomnij, że zgodę można wycofać lub zmienić w dowolnym momencie z banera lub dedykowanego linku."

#: src/PageCompliance/Rules/CookieBannerRules.php:145
msgid "Banner does not rely on scrolling to imply consent"
msgstr "Baner nie wnioskuje zgody z samego przewijania"

#: src/PageCompliance/Rules/CookieBannerRules.php:154
msgid "Phrases like \"By continuing to use the site you agree\" are considered implied consent and fail active-consent rules. Remove them and require an explicit click."
msgstr "Zwroty takie jak \"Kontynuując korzystanie ze strony wyrażasz zgodę\" są uznawane za zgodę dorozumianą i nie spełniają zasad aktywnej zgody. Usuń je i wymagaj wyraźnego kliknięcia."

#: src/PageCompliance/Rules/CookieBannerRules.php:158
msgid "No auto-prompt for push notifications on first load"
msgstr "Brak automatycznego żądania powiadomień push przy pierwszym załadowaniu"

#: src/PageCompliance/Rules/CookieBannerRules.php:170
msgid "Triggering Notification.requestPermission() without prior user interaction is a deceptive pattern (EDPB 03/2022) and is also blocked by modern browsers. Gate push-subscribe prompts behind an explicit user click."
msgstr "Wywoływanie Notification.requestPermission() bez wcześniejszej interakcji użytkownika jest zwodniczym wzorcem (EDPB 03/2022) i jest blokowane przez nowoczesne przeglądarki. Żądania subskrypcji push powinny wymagać wyraźnego kliknięcia użytkownika."

#: src/PageCompliance/Rules/PrivacyPolicyRules.php:33
msgid "Controller identity and contact"
msgstr "Tożsamość i kontakt administratora danych"

#: src/PageCompliance/Rules/PrivacyPolicyRules.php:40
msgid "Add a paragraph identifying the data controller by company name, address and contact details."
msgstr "Dodaj akapit identyfikujący administratora danych przez nazwę firmy, adres i dane kontaktowe."

#: src/PageCompliance/Rules/PrivacyPolicyRules.php:44
msgid "Contact channel (email or form)"
msgstr "Kanał kontaktu (e-mail lub formularz)"

#: src/PageCompliance/Rules/PrivacyPolicyRules.php:53
msgid "Provide an email address or a link to a contact form so users can reach the controller about their data."
msgstr "Udostępnij adres e-mail lub link do formularza kontaktowego, aby użytkownicy mogli skontaktować się z administratorem w sprawie swoich danych."

#: src/PageCompliance/Rules/PrivacyPolicyRules.php:57
msgid "Purposes of processing"
msgstr "Cele przetwarzania"

#: src/PageCompliance/Rules/PrivacyPolicyRules.php:66
msgid "State why you process personal data (e.g. order fulfilment, marketing, legal obligations)."
msgstr "Wskaż, dlaczego przetwarzasz dane osobowe (np. realizacja zamówień, marketing, obowiązki prawne)."

#: src/PageCompliance/Rules/PrivacyPolicyRules.php:70
msgid "Legal basis under RODO Art. 6"
msgstr "Podstawa prawna zgodnie z art. 6 RODO"

#: src/PageCompliance/Rules/PrivacyPolicyRules.php:79
msgid "Reference the legal basis (Art. 6(1)(a) consent, (b) contract, (c) legal obligation, (f) legitimate interest)."
msgstr "Wskaż podstawę prawną (art. 6 ust. 1 lit. a zgoda, b umowa, c obowiązek prawny, f uzasadniony interes)."

#: src/PageCompliance/Rules/PrivacyPolicyRules.php:83
msgid "Retention period"
msgstr "Okres przechowywania"

#: src/PageCompliance/Rules/PrivacyPolicyRules.php:92
msgid "Indicate how long personal data will be retained (fixed period or criteria)."
msgstr "Wskaż, jak długo dane osobowe będą przechowywane (stały okres lub kryteria)."

#: src/PageCompliance/Rules/PrivacyPolicyRules.php:96
msgid "Data recipients (processors)"
msgstr "Odbiorcy danych (podmioty przetwarzające)"

#: src/PageCompliance/Rules/PrivacyPolicyRules.php:106
msgid "List categories of recipients (shipping carriers, payment providers, accounting, IT vendors)."
msgstr "Wymień kategorie odbiorców (przewoźnicy, operatorzy płatności, księgowość, dostawcy IT)."

#: src/PageCompliance/Rules/PrivacyPolicyRules.php:110
msgid "Right of access"
msgstr "Prawo dostępu"

#: src/PageCompliance/Rules/PrivacyPolicyRules.php:117
msgid "State that users can request access to their personal data."
msgstr "Wskaż, że użytkownicy mogą żądać dostępu do swoich danych osobowych."

#: src/PageCompliance/Rules/PrivacyPolicyRules.php:121
msgid "Right to rectification"
msgstr "Prawo do sprostowania"

#: src/PageCompliance/Rules/PrivacyPolicyRules.php:128
msgid "State the right to correct inaccurate personal data."
msgstr "Wskaż prawo do poprawiania nieprawidłowych danych osobowych."

#: src/PageCompliance/Rules/PrivacyPolicyRules.php:132
msgid "Right to erasure (to be forgotten)"
msgstr "Prawo do usunięcia (bycia zapomnianym)"

#: src/PageCompliance/Rules/PrivacyPolicyRules.php:141
msgid "State the right to request deletion of personal data."
msgstr "Wskaż prawo do żądania usunięcia danych osobowych."

#: src/PageCompliance/Rules/PrivacyPolicyRules.php:145
msgid "Right to restriction of processing"
msgstr "Prawo do ograniczenia przetwarzania"

#: src/PageCompliance/Rules/PrivacyPolicyRules.php:152
msgid "State the right to restrict processing in specific situations."
msgstr "Wskaż prawo do ograniczenia przetwarzania w określonych sytuacjach."

#: src/PageCompliance/Rules/PrivacyPolicyRules.php:156
msgid "Right to data portability"
msgstr "Prawo do przenoszenia danych"

#: src/PageCompliance/Rules/PrivacyPolicyRules.php:163
msgid "State the right to receive data in a structured format."
msgstr "Wskaż prawo do otrzymania danych w ustrukturyzowanym formacie."

#: src/PageCompliance/Rules/PrivacyPolicyRules.php:167
msgid "Right to object"
msgstr "Prawo sprzeciwu"

#: src/PageCompliance/Rules/PrivacyPolicyRules.php:175
msgid "State the right to object to processing (especially for marketing)."
msgstr "Wskaż prawo sprzeciwu wobec przetwarzania (zwłaszcza w celach marketingowych)."

#: src/PageCompliance/Rules/PrivacyPolicyRules.php:179
msgid "Right to withdraw consent"
msgstr "Prawo do wycofania zgody"

#: src/PageCompliance/Rules/PrivacyPolicyRules.php:187
msgid "State that consent can be withdrawn at any time where processing is based on consent."
msgstr "Wskaż, że zgodę można wycofać w dowolnym momencie, gdy przetwarzanie odbywa się na podstawie zgody."

#: src/PageCompliance/Rules/PrivacyPolicyRules.php:191
msgid "Right to lodge complaint with UODO"
msgstr "Prawo do wniesienia skargi do UODO"

#: src/PageCompliance/Rules/PrivacyPolicyRules.php:200
msgid "Reference the Polish supervisory authority (Prezes UODO) as the complaint recipient."
msgstr "Wskaż polski organ nadzorczy (Prezes UODO) jako adresata skargi."

#: src/PageCompliance/Rules/PrivacyPolicyRules.php:204
msgid "Automated decision-making / profiling disclosure"
msgstr "Informacja o zautomatyzowanym podejmowaniu decyzji / profilowaniu"

#: src/PageCompliance/Rules/PrivacyPolicyRules.php:212
msgid "Disclose whether automated decision-making or profiling occurs (Art. 13(2)(f))."
msgstr "Ujawnij, czy występuje zautomatyzowane podejmowanie decyzji lub profilowanie (art. 13 ust. 2 lit. f)."

#: src/PageCompliance/Rules/PrivacyPolicyRules.php:216
msgid "International data transfers"
msgstr "Międzynarodowe transfery danych"

#: src/PageCompliance/Rules/PrivacyPolicyRules.php:225
msgid "If you transfer data outside the EEA (e.g. US-based cloud services), disclose the safeguards used."
msgstr "Jeśli przekazujesz dane poza EOG (np. usługi chmurowe w USA), ujawnij stosowane zabezpieczenia."

#: src/PageCompliance/Rules/PrivacyPolicyRules.php:229
msgid "DPO contact (if appointed)"
msgstr "Kontakt do IOD (jeśli wyznaczony)"

#: src/PageCompliance/Rules/PrivacyPolicyRules.php:236
msgid "If you have appointed a Data Protection Officer, publish their contact details."
msgstr "Jeśli wyznaczyłeś Inspektora Ochrony Danych, opublikuj jego dane kontaktowe."

#: src/PageCompliance/Rules/RegulaminRules.php:39
msgid "Service provider identity"
msgstr "Tożsamość usługodawcy"

#: src/PageCompliance/Rules/RegulaminRules.php:48
msgid "Identify the service provider by company name, NIP and REGON."
msgstr "Zidentyfikuj usługodawcę przez nazwę firmy, NIP i REGON."

#: src/PageCompliance/Rules/RegulaminRules.php:52
msgid "Provider contact (address, email)"
msgstr "Kontakt do usługodawcy (adres, e-mail)"

#: src/PageCompliance/Rules/RegulaminRules.php:61
msgid "Provide a registered office address and an email address for customer contact."
msgstr "Podaj adres siedziby i adres e-mail do kontaktu z klientami."

#: src/PageCompliance/Rules/RegulaminRules.php:65
msgid "Scope of services offered"
msgstr "Zakres oferowanych usług"

#: src/PageCompliance/Rules/RegulaminRules.php:74
msgid "Describe what products or services the store sells and to whom."
msgstr "Opisz, jakie produkty lub usługi sprzedaje sklep i komu."

#: src/PageCompliance/Rules/RegulaminRules.php:78
msgid "Technical requirements for using the service"
msgstr "Wymagania techniczne do korzystania z usługi"

#: src/PageCompliance/Rules/RegulaminRules.php:86
msgid "List the technical requirements (browser, internet, optional: account)."
msgstr "Wymień wymagania techniczne (przeglądarka, internet, opcjonalnie: konto)."

#: src/PageCompliance/Rules/RegulaminRules.php:90
msgid "How orders are placed"
msgstr "Sposób składania zamówień"

#: src/PageCompliance/Rules/RegulaminRules.php:99
msgid "Describe the ordering flow (cart, checkout, order confirmation)."
msgstr "Opisz proces zamawiania (koszyk, kasa, potwierdzenie zamówienia)."

#: src/PageCompliance/Rules/RegulaminRules.php:103
msgid "Payment methods"
msgstr "Metody płatności"

#: src/PageCompliance/Rules/RegulaminRules.php:112
msgid "List accepted payment methods (cards, BLIK, bank transfer, pay-on-delivery)."
msgstr "Wymień akceptowane metody płatności (karty, BLIK, przelew, za pobraniem)."

#: src/PageCompliance/Rules/RegulaminRules.php:116
msgid "Delivery methods and times"
msgstr "Metody i czasy dostawy"

#: src/PageCompliance/Rules/RegulaminRules.php:125
msgid "List delivery options with indicative times (couriers, paczkomat, personal pickup)."
msgstr "Wymień opcje dostawy z orientacyjnymi czasami (kurierzy, paczkomat, odbiór osobisty)."

#: src/PageCompliance/Rules/RegulaminRules.php:129
msgid "14-day withdrawal right (consumer)"
msgstr "14-dniowe prawo odstąpienia (konsument)"

#: src/PageCompliance/Rules/RegulaminRules.php:139
msgid "Explicitly state the consumer 14-day right of withdrawal and the return procedure."
msgstr "Wyraźnie wskaż 14-dniowe prawo odstąpienia konsumenta od umowy i procedurę zwrotu."

#: src/PageCompliance/Rules/RegulaminRules.php:143
msgid "Withdrawal form availability"
msgstr "Dostępność formularza odstąpienia"

#: src/PageCompliance/Rules/RegulaminRules.php:150
msgid "Reference the statutory withdrawal form (załącznik do ustawy o prawach konsumenta)."
msgstr "Wskaż ustawowy formularz odstąpienia (załącznik do ustawy o prawach konsumenta)."

#: src/PageCompliance/Rules/RegulaminRules.php:154
msgid "Complaints procedure (reklamacje)"
msgstr "Procedura reklamacji"

#: src/PageCompliance/Rules/RegulaminRules.php:162
msgid "Describe how a customer files a complaint and the timeline for response."
msgstr "Opisz, jak klient składa reklamację i termin odpowiedzi."

#: src/PageCompliance/Rules/RegulaminRules.php:166
msgid "Reference to privacy policy / RODO"
msgstr "Odwołanie do polityki prywatności / RODO"

#: src/PageCompliance/Rules/RegulaminRules.php:176
msgid "Link to the privacy policy and note that RODO/GDPR obligations apply."
msgstr "Dodaj link do polityki prywatności i zaznacz, że obowiązują przepisy RODO/GDPR."

#: src/PageCompliance/Rules/RegulaminRules.php:180
msgid "Amendment procedure for the regulations"
msgstr "Procedura zmiany regulaminu"

#: src/PageCompliance/Rules/RegulaminRules.php:188
msgid "Explain how and with what notice the regulations can be amended."
msgstr "Wyjaśnij, jak i z jakim wyprzedzeniem można zmienić regulamin."

#: src/PageCompliance/Rules/RegulaminRules.php:192
msgid "Governing law"
msgstr "Prawo właściwe"

#: src/PageCompliance/Rules/RegulaminRules.php:200
msgid "State the governing law (typically Polish law for PL-based stores)."
msgstr "Wskaż prawo właściwe (zazwyczaj prawo polskie dla sklepów z siedzibą w Polsce)."

#: src/PageCompliance/Rules/RegulaminRules.php:204
msgid "ODR platform (out-of-court dispute)"
msgstr "Platforma ODR (spór pozasądowy)"

#: src/PageCompliance/Rules/RegulaminRules.php:212
msgid "Link to the EU ODR platform and mention other out-of-court dispute options."
msgstr "Dodaj link do unijnej platformy ODR i wspomnij o innych pozasądowych sposobach rozwiązywania sporów."

#: src/PageCompliance/Rules/RegulaminRules.php:216
msgid "Effective date of the regulations"
msgstr "Data wejścia w życie regulaminu"

#: src/PageCompliance/Rules/RegulaminRules.php:223
msgid "Publish the effective date so customers know which version they agreed to."
msgstr "Opublikuj datę wejścia w życie, aby klienci wiedzieli, na którą wersję wyrazili zgodę."

#: src/Rest/PageComplianceController.php:42
msgid "Legal page type (privacy, terms)."
msgstr "Typ strony prawnej (privacy, terms)."

#: src/Rest/PageComplianceController.php:58
#: src/Rest/PageComplianceController.php:74
msgid "URL to scan; defaults to the site home."
msgstr "URL do skanowania; domyślnie strona główna witryny."

#: src/Rest/PageComplianceController.php:92
msgid "Supported page types: privacy, terms."
msgstr "Obsługiwane typy stron: privacy, terms."

#: src/Service/BusinessInfoService.php:58
msgid "Business identification"
msgstr "Identyfikacja firmy"

#: src/Service/BusinessInfoService.php:59
msgid "Displays the shop's business data (name, NIP, address, contact) from the setup wizard."
msgstr "Wyświetla dane firmowe sklepu (nazwa, NIP, adres, kontakt) z kreatora konfiguracji."

#: src/Service/BusinessInfoService.php:114
#: src/Service/ComplaintTemplateService.php:134
#: src/Service/RodoTrainingDocsService.php:148
msgid "NIP:"
msgstr "NIP:"

#: src/Service/BusinessInfoService.php:117
msgid "REGON:"
msgstr "REGON:"

#: src/Service/ComplaintTemplateService.php:45
