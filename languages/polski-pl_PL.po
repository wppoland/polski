msgstr "Integralność i poufność (bezpieczeństwo)"

#: src/Service/RodoTrainingDocsService.php:193
msgid "Accountability"
msgstr "Rozliczalność"

#: src/Service/RodoTrainingDocsService.php:197
msgid "Right of access (Art. 15)"
msgstr "Prawo dostępu (art. 15)"

#: src/Service/RodoTrainingDocsService.php:198
msgid "Right to rectification (Art. 16)"
msgstr "Prawo do sprostowania (art. 16)"

#: src/Service/RodoTrainingDocsService.php:199
msgid "Right to erasure (Art. 17)"
msgstr "Prawo do usunięcia (art. 17)"

#: src/Service/RodoTrainingDocsService.php:200
msgid "Right to restriction of processing (Art. 18)"
msgstr "Prawo do ograniczenia przetwarzania (art. 18)"

#: src/Service/RodoTrainingDocsService.php:201
msgid "Right to notification about rectification or erasure (Art. 19)"
msgstr "Prawo do powiadomienia o sprostowaniu lub usunięciu (art. 19)"

#: src/Service/RodoTrainingDocsService.php:202
msgid "Right to data portability (Art. 20)"
msgstr "Prawo do przenoszenia danych (art. 20)"

#: src/Service/RodoTrainingDocsService.php:203
msgid "Right to object (Art. 21)"
msgstr "Prawo sprzeciwu (art. 21)"

#: src/Service/RodoTrainingDocsService.php:204
msgid "Right not to be subject to automated decision-making (Art. 22)"
msgstr "Prawo do niepodlegania zautomatyzowanemu podejmowaniu decyzji (art. 22)"

#: src/Service/RodoTrainingDocsService.php:207
msgid "Seven principles of processing (Art. 5)"
msgstr "Siedem zasad przetwarzania (art. 5)"

#: src/Service/RodoTrainingDocsService.php:214
msgid "Eight data subject rights (Chapter III)"
msgstr "Osiem praw osób, których dane dotyczą (rozdział III)"

#: src/Service/RodoTrainingDocsService.php:221
msgid "Operational reminders"
msgstr "Przypomnienia operacyjne"

#: src/Service/RodoTrainingDocsService.php:223
msgid "Never email spreadsheets of personal data - use encrypted channels."
msgstr "Nigdy nie wysyłaj arkuszy z danymi osobowymi e-mailem - korzystaj z szyfrowanych kanałów."

#: src/Service/RodoTrainingDocsService.php:224
msgid "Verify the requester before acting on access or erasure requests."
msgstr "Zweryfikuj wnioskodawcę przed rozpatrzeniem żądania dostępu lub usunięcia."

#: src/Service/RodoTrainingDocsService.php:225
msgid "Log every disclosure to third parties (processors, authorities)."
msgstr "Rejestruj każde ujawnienie danych osobom trzecim (podmioty przetwarzające, organy)."

#: src/Service/RodoTrainingDocsService.php:226
msgid "Report every suspected data breach to the DPO/manager within 24 hours internally."
msgstr "Każde podejrzenie naruszenia danych zgłoś IOD/kierownikowi w ciągu 24 godzin wewnętrznie."

#: src/Service/RodoTrainingDocsService.php:235
msgid "Discovery - record timestamp, discoverer, affected systems."
msgstr "Wykrycie - zapisz znacznik czasu, osobę wykrywającą, systemy, których dotyczy."

#: src/Service/RodoTrainingDocsService.php:236
msgid "Containment - isolate affected accounts/systems within 1 hour."
msgstr "Ograniczenie - izoluj konta/systemy, których dotyczy, w ciągu 1 godziny."

#: src/Service/RodoTrainingDocsService.php:237
msgid "Internal notification - DPO and management within 24 hours."
msgstr "Powiadomienie wewnętrzne - IOD i zarząd w ciągu 24 godzin."

#: src/Service/RodoTrainingDocsService.php:238
msgid "Assessment - document data categories, subjects affected, likely impact."
msgstr "Ocena - udokumentuj kategorie danych, osoby, których dotyczy, prawdopodobny wpływ."

#: src/Service/RodoTrainingDocsService.php:239
msgid "UODO notification - required within 72 hours when risk to subjects is not unlikely."
msgstr "Zgłoszenie do UODO - wymagane w ciągu 72 godzin, gdy ryzyko dla osób nie jest mało prawdopodobne."

#: src/Service/RodoTrainingDocsService.php:240
msgid "Subject notification - required \"without undue delay\" when risk is high."
msgstr "Powiadomienie osoby, której dane dotyczą - wymagane \"bez zbędnej zwłoki\", gdy ryzyko jest wysokie."

#: src/Service/RodoTrainingDocsService.php:241
msgid "Remediation - patch, rotate credentials, review logs."
msgstr "Naprawa - instaluj poprawki, zmień poświadczenia, przejrzyj logi."

#: src/Service/RodoTrainingDocsService.php:242
msgid "Post-mortem - document lessons learned and update training."
msgstr "Analiza powłamaniowa - udokumentuj wnioski i zaktualizuj szkolenia."

#: src/Service/RodoTrainingDocsService.php:245
msgid "Step-by-step breach response"
msgstr "Reagowanie na naruszenie krok po kroku"

#: src/Service/RodoTrainingDocsService.php:252
msgid "Breach log template"
msgstr "Szablon dziennika naruszeń"

#: src/Service/RodoTrainingDocsService.php:254
msgid "Field"
msgstr "Pole"

#: src/Service/RodoTrainingDocsService.php:257
msgid "Incident ID"
msgstr "ID incydentu"

#: src/Service/RodoTrainingDocsService.php:258
msgid "Detected at (UTC)"
msgstr "Wykryto o (UTC)"

#: src/Service/RodoTrainingDocsService.php:259
msgid "Detected by"
msgstr "Wykryte przez"

#: src/Service/RodoTrainingDocsService.php:260
msgid "Affected systems"
msgstr "Systemy, których dotyczy"

#: src/Service/RodoTrainingDocsService.php:261
msgid "Affected data categories"
msgstr "Kategorie danych, których dotyczy"

#: src/Service/RodoTrainingDocsService.php:262
msgid "Approximate number of subjects"
msgstr "Przybliżona liczba osób"

#: src/Service/RodoTrainingDocsService.php:263
msgid "Likely impact"
msgstr "Prawdopodobny wpływ"

#: src/Service/RodoTrainingDocsService.php:264
msgid "Containment actions"
msgstr "Działania ograniczające"

#: src/Service/RodoTrainingDocsService.php:265
msgid "UODO notified at"
msgstr "Powiadomienie UODO o"

#: src/Service/RodoTrainingDocsService.php:266
msgid "Subjects notified at"
msgstr "Powiadomienie osób o"

#: src/Service/RodoTrainingDocsService.php:274
msgid "UODO notification channel:"
msgstr "Kanał zgłoszenia do UODO:"

#: src/Service/SiteAuditService.php:138
msgid "Forced account creation (dark pattern)"
msgstr "Wymuszone utworzenie konta (dark pattern)"

#: src/Service/SiteAuditService.php:147
msgid "Guest checkout is enabled. Customers are not forced to create an account."
msgstr "Zakupy jako gość są włączone. Klienci nie są zmuszani do tworzenia konta."

#: src/Service/SiteAuditService.php:155
msgid "Guest checkout is disabled AND login is required — customers are forced to create an account. EU Directive 2023/2673 considers this a dark pattern unless justified (e.g. B2B). Enable guest checkout under WooCommerce > Settings > Accounts."
msgstr "Zakupy jako gość są wyłączone ORAZ wymagane jest logowanie - klienci są zmuszani do tworzenia konta. Dyrektywa UE 2023/2673 uznaje to za dark pattern, chyba że jest uzasadnione (np. B2B). Włącz zakupy jako gość w WooCommerce > Ustawienia > Konta."

#: src/Service/SiteAuditService.php:162
msgid "Guest checkout is disabled. If this is not a B2B-only store, enable guest checkout under WooCommerce > Settings > Accounts."
msgstr "Zakupy jako gość są wyłączone. Jeśli to nie jest sklep wyłącznie B2B, włącz zakupy jako gość w WooCommerce > Ustawienia > Konta."

#: src/Service/SiteAuditService.php:175
msgid "Stale or fake sale countdown (dark pattern)"
msgstr "Nieaktualny lub fałszywy odliczanie promocji (dark pattern)"

#: src/Service/SiteAuditService.php:181
#: src/Service/SiteAuditService.php:258
msgid "WooCommerce not active."
msgstr "WooCommerce nie jest aktywny."

#: src/Service/SiteAuditService.php:197
msgid "No products to scan."
msgstr "Brak produktów do zeskanowania."

#: src/Service/SiteAuditService.php:228
msgid "No products with expired sale dates are still on sale."
msgstr "Żaden produkt z wygasłą datą promocji nie jest już w promocji."

#. translators: %d: number of products
#: src/Service/SiteAuditService.php:237
#, php-format
msgid "%d product(s) have a sale-to date in the past but still appear on sale. Ensure your countdown or promo widgets do not silently reset after expiry."
msgstr "%d produkt(ów) ma datę końca promocji w przeszłości, ale nadal wyświetla się jako w promocji. Upewnij się, że odliczania i widżety promocyjne nie resetują się po cichu po wygaśnięciu."

#: src/Service/SiteAuditService.php:252
msgid "Misleading \"from\" price on variable products"
msgstr "Mylna cena \"od\" w produktach wariantowych"

#: src/Service/SiteAuditService.php:273
msgid "No variable products to scan."
msgstr "Brak produktów wariantowych do zeskanowania."

#: src/Service/SiteAuditService.php:302
msgid "All variable products have a reasonable min/max price spread."
msgstr "Wszystkie produkty wariantowe mają rozsądny rozrzut cen min/max."

#. translators: %d: number of products
#: src/Service/SiteAuditService.php:311
#, php-format
msgid "%d variable product(s) show a \"from\" price where the cheapest variant is less than 50%% of the most expensive. Consider showing a price range or clarifying the variant context to avoid misleading buyers."
msgstr "%d produkt(ów) wariantowych pokazuje cenę \"od\", gdzie najtańszy wariant stanowi mniej niż 50%% ceny najdroższego. Rozważ wyświetlanie zakresu cen lub doprecyzowanie kontekstu wariantu, aby nie wprowadzać kupujących w błąd."

#: src/Service/SiteAuditService.php:325
msgid "False urgency via low-stock threshold (dark pattern)"
msgstr "Fałszywa presja czasu przez próg niskiego stanu (dark pattern)"

#. translators: %d: threshold value
#: src/Service/SiteAuditService.php:335
#, php-format
msgid "Low-stock threshold is %d, within a reasonable range."
msgstr "Próg niskiego stanu wynosi %d, w rozsądnym zakresie."

#. translators: %d: threshold value
#: src/Service/SiteAuditService.php:346
#, php-format
msgid "Low-stock threshold is %d, which is high. A threshold above 5 can make \"Only X left\" appear on plentiful stock and create artificial urgency. Consider lowering it under WooCommerce > Settings > Products > Inventory."
msgstr "Próg niskiego stanu wynosi %d, co jest wysoką wartością. Próg powyżej 5 może powodować wyświetlanie \"Zostało tylko X\" przy obfitym zapasie i tworzyć sztuczną presję czasu. Rozważ jego obniżenie w WooCommerce > Ustawienia > Produkty > Zapasy."