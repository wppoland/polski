msgid "DPA registry module is disabled. It is good practice to monitor DPA status for hosting, payments, etc."
msgstr "Moduł rejestru DPA jest wyłączony. Dobrą praktyką jest monitorowanie statusu DPA dla hostingu, płatności itp."

#: src/Service/SiteAuditService.php:607
msgid "DPA module is enabled, but the registry is empty. Mark at least hosting, payments, and other data processing services."
msgstr "Moduł DPA jest włączony, ale rejestr jest pusty. Zaznacz co najmniej hosting, płatności i inne usługi przetwarzania danych."

#: src/Service/SiteAuditService.php:615
msgid "DPA registry has no active data processing agreements marked."
msgstr "Rejestr DPA nie ma zaznaczonych aktywnych umów powierzenia przetwarzania danych."

#. translators: 1: number of services with DPA, 2: number of tracked services
#: src/Service/SiteAuditService.php:625
#, php-format
msgid "Only %1$d of %2$d tracked services have a data processing agreement marked."
msgstr "Tylko %1$d z %2$d śledzonych usług ma zaznaczoną umowę powierzenia przetwarzania danych."

#. translators: %d: number of tracked services
#: src/Service/SiteAuditService.php:637
#, php-format
msgid "DPA registry covers %d services and all have an agreement status marked."
msgstr "Rejestr DPA obejmuje %d usług i wszystkie mają zaznaczony status umowy."

#: src/Service/SiteAuditService.php:650
msgid "Security incident registry"
msgstr "Rejestr incydentów bezpieczeństwa"

#: src/Service/SiteAuditService.php:656
msgid "Security incident module is disabled. It is good practice to maintain a simple incident registry for compliance."
msgstr "Moduł incydentów bezpieczeństwa jest wyłączony. Dobrą praktyką jest prowadzenie prostego rejestru incydentów."

#: src/Service/SiteAuditService.php:670
msgid "Incident module is enabled, but no security contact email is set."
msgstr "Moduł incydentów jest włączony, ale nie ustawiono adresu e-mail kontaktu bezpieczeństwa."

#: src/Service/SiteAuditService.php:678
msgid "Incident module is enabled and security contact is set. The registry is currently empty."
msgstr "Moduł incydentów jest włączony i kontakt bezpieczeństwa jest ustawiony. Rejestr jest obecnie pusty."

#. translators: %d: number of open incidents
#: src/Service/SiteAuditService.php:697
#, php-format
msgid "There are %d open security incidents requiring further action in the registry."
msgstr "W rejestrze jest %d otwartych incydentów bezpieczeństwa wymagających dalszych działań."

#: src/Service/SiteAuditService.php:700
msgid "The incident registry is active and has no open cases."
msgstr "Rejestr incydentów jest aktywny i nie ma otwartych spraw."

#: src/Service/SiteAuditService.php:711
msgid "SSL/TLS encryption"
msgstr "Szyfrowanie SSL/TLS"

#: src/Service/SiteAuditService.php:717
