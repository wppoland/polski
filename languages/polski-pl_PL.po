msgstr "Prawo dostępu (art. 15)"

#: src/Service/RodoTrainingDocsService.php:198
msgid "Right to rectification (Art. 16)"
msgstr "Prawo do sprostowania (art. 16)"

#: src/Service/RodoTrainingDocsService.php:199
msgid "Right to erasure (Art. 17)"
msgstr "Prawo do usunięcia (art. 17)"

#: src/Service/RodoTrainingDocsService.php:200
msgid "Right to restriction of processing (Art. 18)"
msgstr "Prawo do ograniczenia przetwarzania (art. 18)"

#: src/Service/RodoTrainingDocsService.php:201
msgid "Right to notification about rectification or erasure (Art. 19)"
msgstr "Prawo do powiadomienia o sprostowaniu lub usunięciu (art. 19)"

#: src/Service/RodoTrainingDocsService.php:202
msgid "Right to data portability (Art. 20)"
msgstr "Prawo do przenoszenia danych (art. 20)"

#: src/Service/RodoTrainingDocsService.php:203
msgid "Right to object (Art. 21)"
msgstr "Prawo sprzeciwu (art. 21)"

#: src/Service/RodoTrainingDocsService.php:204
msgid "Right not to be subject to automated decision-making (Art. 22)"
msgstr "Prawo do niepodlegania zautomatyzowanemu podejmowaniu decyzji (art. 22)"

#: src/Service/RodoTrainingDocsService.php:207
msgid "Seven principles of processing (Art. 5)"
msgstr "Siedem zasad przetwarzania (art. 5)"

#: src/Service/RodoTrainingDocsService.php:214
msgid "Eight data subject rights (Chapter III)"
msgstr "Osiem praw osób, których dane dotyczą (rozdział III)"

#: src/Service/RodoTrainingDocsService.php:221
msgid "Operational reminders"
msgstr "Przypomnienia operacyjne"

#: src/Service/RodoTrainingDocsService.php:223
msgid "Never email spreadsheets of personal data - use encrypted channels."
msgstr "Nigdy nie wysyłaj arkuszy z danymi osobowymi e-mailem - korzystaj z szyfrowanych kanałów."

#: src/Service/RodoTrainingDocsService.php:224
msgid "Verify the requester before acting on access or erasure requests."
msgstr "Zweryfikuj wnioskodawcę przed rozpatrzeniem żądania dostępu lub usunięcia."

#: src/Service/RodoTrainingDocsService.php:225
msgid "Log every disclosure to third parties (processors, authorities)."
msgstr "Rejestruj każde ujawnienie danych osobom trzecim (podmioty przetwarzające, organy)."

#: src/Service/RodoTrainingDocsService.php:226
msgid "Report every suspected data breach to the DPO/manager within 24 hours internally."
msgstr "Każde podejrzenie naruszenia danych zgłoś IOD/kierownikowi w ciągu 24 godzin wewnętrznie."

#: src/Service/RodoTrainingDocsService.php:235
msgid "Discovery - record timestamp, discoverer, affected systems."
msgstr "Wykrycie - zapisz znacznik czasu, osobę wykrywającą, systemy, których dotyczy."

#: src/Service/RodoTrainingDocsService.php:236
msgid "Containment - isolate affected accounts/systems within 1 hour."
msgstr "Ograniczenie - izoluj konta/systemy, których dotyczy, w ciągu 1 godziny."

#: src/Service/RodoTrainingDocsService.php:237
msgid "Internal notification - DPO and management within 24 hours."
msgstr "Powiadomienie wewnętrzne - IOD i zarząd w ciągu 24 godzin."

#: src/Service/RodoTrainingDocsService.php:238
msgid "Assessment - document data categories, subjects affected, likely impact."
msgstr "Ocena - udokumentuj kategorie danych, osoby, których dotyczy, prawdopodobny wpływ."

#: src/Service/RodoTrainingDocsService.php:239
msgid "UODO notification - required within 72 hours when risk to subjects is not unlikely."
msgstr "Zgłoszenie do UODO - wymagane w ciągu 72 godzin, gdy ryzyko dla osób nie jest mało prawdopodobne."

#: src/Service/RodoTrainingDocsService.php:240
msgid "Subject notification - required \"without undue delay\" when risk is high."
msgstr "Powiadomienie osoby, której dane dotyczą - wymagane \"bez zbędnej zwłoki\", gdy ryzyko jest wysokie."

#: src/Service/RodoTrainingDocsService.php:241
