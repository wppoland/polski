msgstr "Der Kunde hat einen Widerrufsantrag gestellt."

#: config/defaults.php:165
msgid "Wniosek o odstąpienie został potwierdzony."
msgstr "Der Widerrufsantrag wurde bestätigt."

#: config/defaults.php:167
msgid "Potwierdzenie wniosku o odstąpienie od zamówienia nr #{order_number}"
msgstr "Bestätigung des Widerrufsantrags für Bestellung Nr. #{order_number}"

#: config/defaults.php:168
msgid "Odstąpienie potwierdzone"
msgstr "Widerruf bestätigt"

#: config/defaults.php:169 config/defaults.php:198
#: templates/emails/double-opt-in.php:24
#: templates/emails/plain/double-opt-in.php:20
msgid "Cześć {name},"
msgstr "Hallo {name},"

#: config/defaults.php:170
