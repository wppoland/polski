#: src/Admin/DeactivationHandler.php:58
msgid "Polski for WooCommerce"
msgstr "Polski für WooCommerce"

#. Plugin URI of the plugin
#: polski.php
msgid "https://wppoland.com/pl/polski/"
msgstr "https://wppoland.com/de/polski/"

#. Description of the plugin
#: polski.php
msgid "Adapts WooCommerce and WordPress to Polish market requirements: GPSR, Omnibus, GDPR, unit prices, withdrawal forms, and storefront tools."
msgstr "Passt WooCommerce und WordPress an die Anforderungen des polnischen Marktes an: GPSR, Omnibus, DSGVO, Grundpreise, Widerrufsformulare und Storefront-Werkzeuge."

