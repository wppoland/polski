#: src/Service/AbilitiesService.php:58
msgid "Polski — withdrawal"
msgstr "Polski - Widerruf"

#: src/Service/AbilitiesService.php:59
msgid "Consumer right of withdrawal (14-day return) operations."
msgstr "Vorgänge zum Verbraucher-Widerrufsrecht (14-tägige Rückgabe)."

#: src/Service/AbilitiesService.php:63
msgid "Polski — legal documents"
msgstr "Polski - rechtliche Dokumente"

#: src/Service/AbilitiesService.php:64
msgid "Generated consumer-law documents (Annex I(A), I(B), etc.)."
msgstr "Generierte verbraucherrechtliche Dokumente (Anlage I(A), I(B) usw.)."

