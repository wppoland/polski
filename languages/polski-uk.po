#. Plugin Name of the plugin
#: polski.php
#: src/Admin/DeactivationHandler.php:58
msgid "Polski for WooCommerce"
msgstr "Polski для WooCommerce"

#. Plugin URI of the plugin
#: polski.php
msgid "https://wppoland.com/pl/polski/"
msgstr "https://wppoland.com/pl/polski/"

#. Description of the plugin
#: polski.php
msgid "Adapts WooCommerce and WordPress to Polish market requirements: GPSR, Omnibus, GDPR, unit prices, withdrawal forms, and storefront tools."
msgstr "Адаптує WooCommerce та WordPress до вимог польського ринку: GPSR, Omnibus, GDPR, ціни за одиницю, форми відмови від договору та інструменти вітрини."

#. Author of the plugin
#: polski.php
msgid "WPPoland"
msgstr "WPPoland"

#. Author URI of the plugin
#: polski.php
msgid "https://wppoland.com"
msgstr "https://wppoland.com"

