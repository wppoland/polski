#. Plugin Name of the plugin
#: polski.php src/Admin/DeactivationHandler.php:58 src/Admin/SBOMPage.php:113
msgid "Polski for WooCommerce"
msgstr "Polski для WooCommerce"

#. Plugin URI of the plugin
#: polski.php
msgid "https://wppoland.com/pl/polski/"
msgstr "https://wppoland.com/pl/polski/"

#. Description of the plugin
#: polski.php
msgid ""
"Adds product information, checkout, consent, and storefront tools for "
"WooCommerce stores serving customers in Poland."
msgstr ""
"Додає інструменти для інформації про товар, оформлення замовлення, згоди та "
"вітрини магазину для магазинів WooCommerce, що обслуговують клієнтів у "
"Польщі."

#. Author of the plugin
#: polski.php
msgid "WPPoland"
msgstr "WPPoland"

#. Author URI of the plugin
#: polski.php
msgid "https://wppoland.com"
msgstr "https://wppoland.com"

#: config/defaults.php:18
msgid "Platforma ODR: https://ec.europa.eu/consumers/odr"
msgstr "Платформа ODR: https://ec.europa.eu/consumers/odr"

#: config/defaults.php:19
msgid ""
"Gotowe! Wygenerowaliśmy dla Ciebie wstępne szkice stron prawnych. Przejrzyj "
"je, dostosuj do swoich potrzeb i śmiało opublikuj."
msgstr ""
"Готово! Ми створили для вас попередні чернетки правових сторінок. "
"Перегляньте їх, адаптуйте під свої потреби та сміливо публікуйте."

#: config/defaults.php:20
msgid "Moduły zapisane."
msgstr "Модулі збережено."

#: config/defaults.php:21
msgid "Skonfiguruj Polski dla Twojego sklepu"
msgstr "Налаштуйте Polski для вашого магазину"

#: config/defaults.php:22
msgid ""
"Jeszcze chwila i sklep będzie gotowy. Przejrzyj moduły, ustaw strony prawne "
"i domknij konfigurację w panelu Polski."
msgstr ""
"Ще мить - і магазин буде готовий. Перегляньте модулі, налаштуйте правові "
"сторінки та завершіть конфігурацію в панелі Polski."

#: config/defaults.php:23
msgid "Otwórz konfigurację Polski"
msgstr "Відкрити конфігурацію Polski"

#: config/defaults.php:24
msgid "Aktywna"
msgstr "Активна"

#: config/defaults.php:25
msgid "Wyłączona"
msgstr "Вимкнена"

#: config/defaults.php:26
msgid "Nieskonfigurowany"
msgstr "Не налаштовано"

#: config/defaults.php:27 config/defaults.php:33
msgid "Strony prawne"
msgstr "Правові сторінки"

#: config/defaults.php:28
msgid "Masz już za sobą {done} z {total} kroków. Znakomicie!"
msgstr "Ви вже виконали {done} з {total} кроків. Чудово!"

#: config/defaults.php:29
msgid "Wyświetlanie podatku"
msgstr "Відображення податку"

#: config/defaults.php:30
msgid "Zwolnienie podmiotowe (art. 113)"
msgstr "Суб'єктне звільнення (ст. 113)"

