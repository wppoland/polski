#: src/Privacy/WithdrawalPrivacyService.php:68
#: src/Privacy/WithdrawalPrivacyService.php:206
msgid "Polski Withdrawal Declarations"
msgstr "Polski - заяви про відступлення"

#: src/Privacy/WithdrawalPrivacyService.php:54
