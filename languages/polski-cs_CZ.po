msgid "Trainer"
msgstr "Školitel"

#: src/Service/RodoTrainingDocsService.php:169
msgid "Signature"
msgstr "Podpis"

#: src/Service/RodoTrainingDocsService.php:187
msgid "Lawfulness, fairness and transparency"
msgstr "Zákonnost, korektnost a transparentnost"

#: src/Service/RodoTrainingDocsService.php:188
msgid "Purpose limitation"
msgstr "Omezení účelu"

#: src/Service/RodoTrainingDocsService.php:189
msgid "Data minimisation"
msgstr "Minimalizace údajů"

#: src/Service/RodoTrainingDocsService.php:190
msgid "Accuracy"
msgstr "Přesnost"

#: src/Service/RodoTrainingDocsService.php:191
msgid "Storage limitation"
msgstr "Omezení uložení"

#: src/Service/RodoTrainingDocsService.php:192
msgid "Integrity and confidentiality (security)"
msgstr "Integrita a důvěrnost (bezpečnost)"

#: src/Service/RodoTrainingDocsService.php:193
msgid "Accountability"
msgstr "Odpovědnost"

#: src/Service/RodoTrainingDocsService.php:197
msgid "Right of access (Art. 15)"
msgstr "Právo na přístup (čl. 15)"

#: src/Service/RodoTrainingDocsService.php:198
msgid "Right to rectification (Art. 16)"
msgstr "Právo na opravu (čl. 16)"

#: src/Service/RodoTrainingDocsService.php:199
msgid "Right to erasure (Art. 17)"
msgstr "Právo na výmaz (čl. 17)"

#: src/Service/RodoTrainingDocsService.php:200
msgid "Right to restriction of processing (Art. 18)"
msgstr "Právo na omezení zpracování (čl. 18)"

#: src/Service/RodoTrainingDocsService.php:201
msgid "Right to notification about rectification or erasure (Art. 19)"
msgstr "Právo na oznámení o opravě nebo výmazu (čl. 19)"

#: src/Service/RodoTrainingDocsService.php:202
msgid "Right to data portability (Art. 20)"
msgstr "Právo na přenositelnost údajů (čl. 20)"

#: src/Service/RodoTrainingDocsService.php:203
msgid "Right to object (Art. 21)"
msgstr "Právo vznést námitku (čl. 21)"

#: src/Service/RodoTrainingDocsService.php:204
msgid "Right not to be subject to automated decision-making (Art. 22)"
msgstr "Právo nebýt předmětem automatizovaného rozhodování (čl. 22)"

#: src/Service/RodoTrainingDocsService.php:207
msgid "Seven principles of processing (Art. 5)"
msgstr "Sedm zásad zpracování (čl. 5)"

#: src/Service/RodoTrainingDocsService.php:214
msgid "Eight data subject rights (Chapter III)"
msgstr "Osm práv subjektů údajů (kapitola III)"

#: src/Service/RodoTrainingDocsService.php:221
msgid "Operational reminders"
msgstr "Provozní připomenutí"

#: src/Service/RodoTrainingDocsService.php:223
msgid "Never email spreadsheets of personal data - use encrypted channels."
msgstr ""
"Nikdy neposílejte e-mailem tabulky s osobními údaji - používejte šifrované "
"kanály."

#: src/Service/RodoTrainingDocsService.php:224
msgid "Verify the requester before acting on access or erasure requests."
msgstr "Před vyřízením žádosti o přístup nebo výmaz ověřte žadatele."

#: src/Service/RodoTrainingDocsService.php:225
msgid "Log every disclosure to third parties (processors, authorities)."
msgstr ""
"Zaznamenávejte každé poskytnutí údajů třetím stranám (zpracovatelé, úřady)."

#: src/Service/RodoTrainingDocsService.php:226
msgid ""
"Report every suspected data breach to the DPO/manager within 24 hours "
"internally."
msgstr ""
"Každé podezření na narušení ochrany údajů nahlaste DPO/manažerovi interně do"
" 24 hodin."

#: src/Service/RodoTrainingDocsService.php:235
msgid "Discovery - record timestamp, discoverer, affected systems."
msgstr ""
"Zjištění - zaznamenejte časové razítko, osobu, která zjištění provedla, "
"dotčené systémy."

#: src/Service/RodoTrainingDocsService.php:236
msgid "Containment - isolate affected accounts/systems within 1 hour."
msgstr "Zamezení šíření - izolujte dotčené účty/systémy do 1 hodiny."

#: src/Service/RodoTrainingDocsService.php:237
msgid "Internal notification - DPO and management within 24 hours."
msgstr "Interní oznámení - DPO a vedení do 24 hodin."

#: src/Service/RodoTrainingDocsService.php:238
msgid ""
"Assessment - document data categories, subjects affected, likely impact."
msgstr ""
"Posouzení - zdokumentujte kategorie údajů, dotčené subjekty, pravděpodobný "
"dopad."

#: src/Service/RodoTrainingDocsService.php:239
msgid ""
"UODO notification - required within 72 hours when risk to subjects is not "
"unlikely."
msgstr ""
"Oznámení UODO - vyžadováno do 72 hodin, pokud riziko pro subjekty není "
"nepravděpodobné."

#: src/Service/RodoTrainingDocsService.php:240
msgid "Subject notification - required \"without undue delay\" when risk is high."
msgstr ""
"Oznámení subjektu - vyžadováno \"bez zbytečného odkladu\", pokud je riziko "
"vysoké."

#: src/Service/RodoTrainingDocsService.php:241
msgid "Remediation - patch, rotate credentials, review logs."
msgstr ""
"Náprava - aplikujte záplaty, změňte přihlašovací údaje, prozkoumejte logy."

#: src/Service/RodoTrainingDocsService.php:242
msgid "Post-mortem - document lessons learned and update training."
msgstr ""
"Analýza po incidentu - zdokumentujte získané poznatky a aktualizujte "
"školení."

#: src/Service/RodoTrainingDocsService.php:245
msgid "Step-by-step breach response"
msgstr "Reakce na narušení krok za krokem"

#: src/Service/RodoTrainingDocsService.php:252
msgid "Breach log template"
msgstr "Šablona deníku narušení"

