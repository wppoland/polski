msgid "Field"
msgstr "Pole"

#: src/Service/RodoTrainingDocsService.php:257
msgid "Incident ID"
msgstr "ID incidentu"

#: src/Service/RodoTrainingDocsService.php:258
msgid "Detected at (UTC)"
msgstr "Zjištěno v (UTC)"

#: src/Service/RodoTrainingDocsService.php:259
msgid "Detected by"
msgstr "Zjistil"

#: src/Service/RodoTrainingDocsService.php:260
