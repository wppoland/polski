#. Plugin Name of the plugin
#: polski.php
#: src/Admin/DeactivationHandler.php:58
msgid "Polski for WooCommerce"
msgstr "Polski pro WooCommerce"

#. Plugin URI of the plugin
#: polski.php
msgid "https://wppoland.com/pl/polski/"
msgstr "https://wppoland.com/cs/polski/"

#. Description of the plugin
#: polski.php
msgid "Adapts WooCommerce and WordPress to Polish market requirements: GPSR, Omnibus, GDPR, unit prices, withdrawal forms, and storefront tools."
msgstr "Přizpůsobuje WooCommerce a WordPress požadavkům polského trhu: GPSR, Omnibus, GDPR, jednotkové ceny, formuláře odstoupení a nástroje storefrontu."

