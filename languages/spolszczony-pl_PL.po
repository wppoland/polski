# Checkout
msgid "I have read and accept the <a href=\"%s\" target=\"_blank\">Terms and Conditions</a>."
msgstr "Zapoznalem/am sie i akceptuje <a href=\"%s\" target=\"_blank\">Regulamin sklepu</a>."

msgid "You must accept the Terms and Conditions to place an order."
msgstr "Musisz zaakceptowac Regulamin, aby zlozyc zamowienie."

msgid "Terms and Conditions acceptance (Regulamin sklepu)."
msgstr "Akceptacja Regulaminu sklepu."

msgid "I have read and accept the <a href=\"%s\" target=\"_blank\">Privacy Policy</a>."
msgstr "Zapoznalem/am sie i akceptuje <a href=\"%s\" target=\"_blank\">Polityke prywatnosci</a>."

msgid "You must accept the Privacy Policy."
msgstr "Musisz zaakceptowac Polityke prywatnosci."

msgid "Privacy Policy acceptance (Polityka prywatnosci)."
msgstr "Akceptacja Polityki prywatnosci."

msgid "I have been informed about my <a href=\"%s\" target=\"_blank\">right to withdraw from the contract</a> within 14 days."
msgstr "Zostal/am poinformowany/a o moim <a href=\"%s\" target=\"_blank\">prawie odstapienia od umowy</a> w ciagu 14 dni."

msgid "You must acknowledge the withdrawal rights information."
msgstr "Musisz potwierdzic zapoznanie sie z informacja o prawie odstapienia."

msgid "14-day withdrawal right acknowledgment (Prawo odstapienia)."
msgstr "Potwierdzenie prawa odstapienia od umowy (14 dni)."

msgid "I agree that the digital content delivery begins immediately and I acknowledge that I lose my right to withdraw from the contract."
msgstr "Wyrazam zgode na rozpoczecie dostarczania tresci cyfrowych przed uplywem terminu do odstapienia od umowy i przyjmuje do wiadomosci utrate prawa odstapienia."

msgid "You must consent to immediate digital content delivery."
msgstr "Musisz wyrazic zgode na natychmiastowe dostarczenie tresci cyfrowych."

msgid "Waiver of withdrawal right for digital goods."
msgstr "Zrzeczenie sie prawa odstapienia dla towarow cyfrowych."

msgid "I agree to receive SMS/email notifications about parcel delivery status."
msgstr "Wyrazam zgode na otrzymywanie powiadomien SMS/email o statusie dostawy przesylki."

msgid "Optional consent for delivery notifications."
msgstr "Opcjonalna zgoda na powiadomienia o dostawie."

msgid "I agree to receive a product review reminder by email after my purchase."
msgstr "Wyrazam zgode na otrzymanie przypomnienia o wystawieniu opinii drog mailowa po zakupie."

msgid "Optional consent for review reminder emails."
msgstr "Opcjonalna zgoda na przypomnienia o opinii."

msgid "I agree to receive marketing communications and newsletters."
msgstr "Wyrazam zgode na otrzymywanie komunikacji marketingowej i newslettera."

msgid "Optional marketing consent (GDPR Art. 6.1.a)."
msgstr "Opcjonalna zgoda marketingowa (RODO art. 6 ust. 1 lit. a)."

msgid "Please accept: %s"
msgstr "Prosze zaakceptowac: %s"

