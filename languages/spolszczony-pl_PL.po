# Product meta box
msgid "Unit Price (Cena jednostkowa)"
msgstr "Cena jednostkowa"

msgid "Product amount"
msgstr "Ilosc produktu"

msgid "Amount of product in the package (e.g., 500 for 500g)."
msgstr "Ilosc produktu w opakowaniu (np. 500 dla 500g)."

msgid "Base amount"
msgstr "Ilosc bazowa"

msgid "The reference base amount (e.g., 1 for \"per 1 kg\", 100 for \"per 100 ml\")."
msgstr "Bazowa ilosc referencyjna (np. 1 dla \"za 1 kg\", 100 dla \"za 100 ml\")."

msgid "Measurement unit for the unit price display."
msgstr "Jednostka miary dla wyswietlania ceny jednostkowej."

msgid "Estimated delivery time displayed on product page."
msgstr "Szacowany czas dostawy wyswietlany na stronie produktu."

msgid "Withdrawal exempt"
msgstr "Wylaczenie z prawa odstapienia"

msgid "This product is exempt from the 14-day withdrawal right (e.g., digital content, perishable goods)."
msgstr "Ten produkt jest wylaczony z 14-dniowego prawa odstapienia (np. tresci cyfrowe, towary latwo psujace sie)."

# Withdrawal
msgid "Withdrawal Request"
msgstr "Wniosek o odstapienie"

msgid "Status"
msgstr "Status"

msgid "Submitted"
msgstr "Zlozono"

msgid "Requested"
msgstr "Zlozony"

msgid "Confirmed"
msgstr "Potwierdzony"

msgid "Completed"
msgstr "Zakonczony"

msgid "Rejected"
msgstr "Odrzucony"

msgid "Withdraw"
msgstr "Odstap od umowy"

msgid "Your withdrawal request has been submitted. You will receive a confirmation email."
msgstr "Twoj wniosek o odstapienie zostal zlozony. Otrzymasz potwierdzenie e-mailem."

msgid "This order is not eligible for withdrawal."
msgstr "To zamowienie nie kwalifikuje sie do odstapienia."

msgid "Invalid request. Please try again."
msgstr "Nieprawidlowe zadanie. Sprobuj ponownie."

msgid "Order not found."
msgstr "Zamowienie nie zostalo znalezione."

msgid "You do not have permission to withdraw this order."
msgstr "Nie masz uprawnien do odstapienia od tego zamowienia."

msgid "Reason for withdrawal (optional)"
msgstr "Powod odstapienia (opcjonalnie)"

msgid "Customer submitted a withdrawal request."
msgstr "Klient zlozyl wniosek o odstapienie od umowy."

msgid "Withdrawal request confirmed."
msgstr "Wniosek o odstapienie potwierdzony."

# Withdrawal form
msgid "You are requesting withdrawal from order #%1$s placed on %2$s."
msgstr "Skladasz wniosek o odstapienie od zamowienia #%1$s zlozonego dnia %2$s."

msgid "According to Polish law, you have the right to withdraw from the contract within 14 days without giving any reason."
msgstr "Zgodnie z polskim prawem masz prawo odstapic od umowy w ciagu 14 dni bez podania przyczyny."

msgid "Order Items"
msgstr "Produkty z zamowienia"

msgid "Product"
msgstr "Produkt"

msgid "Quantity"
msgstr "Ilosc"

msgid "Price"
msgstr "Cena"

msgid "(Not eligible for withdrawal)"
msgstr "(Nie podlega prawu odstapienia)"

msgid "Submit Withdrawal Request"
msgstr "Zloz wniosek o odstapienie"

# Emails
msgid "Withdrawal Confirmation"
msgstr "Potwierdzenie odstapienia"

msgid "Sent to the customer when their withdrawal request is confirmed."
msgstr "Wysylane do klienta po potwierdzeniu wniosku o odstapienie."

msgid "Your withdrawal request for order #{order_number} has been confirmed"
msgstr "Twoj wniosek o odstapienie od zamowienia #{order_number} zostal potwierdzony"

msgid "Withdrawal Confirmed"
msgstr "Odstapienie potwierdzone"

msgid "Dear %s,"
msgstr "Szanowny/a %s,"

msgid "Your withdrawal request for order #%s has been confirmed."
msgstr "Twoj wniosek o odstapienie od zamowienia #%s zostal potwierdzony."

msgid "Your reason:"
msgstr "Twoj powod:"

msgid "Please return the items to the following address within 14 days:"
msgstr "Prosimy o zwrot produktow na ponizszy adres w ciagu 14 dni:"

msgid "Your refund will be processed within 14 days from the date we receive the returned items."
msgstr "Zwrot srodkow zostanie zrealizowany w ciagu 14 dni od daty otrzymania zwroconych produktow."

msgid "Account Activation (Double Opt-In)"
msgstr "Aktywacja konta (Podwojna weryfikacja)"

msgid "Sent to new customers to verify their email address."
msgstr "Wysylane do nowych klientow w celu weryfikacji adresu email."

msgid "Activate your account at {site_title}"
msgstr "Aktywuj swoje konto w {site_title}"

msgid "Confirm your email address"
msgstr "Potwierdz swoj adres email"

msgid "If you did not create an account, you can safely ignore this email."
msgstr "Jezeli nie zakladales/as konta, mozesz bezpiecznie zignorowac te wiadomosc."

msgid "Hello %s,"
msgstr "Witaj %s,"

msgid "Thank you for creating an account. Please click the button below to activate your account:"
msgstr "Dziekujemy za utworzenie konta. Kliknij ponizszy przycisk, aby je aktywowac:"

msgid "Activate Account"
msgstr "Aktywuj konto"

msgid "Or copy and paste this link into your browser:"
msgstr "Lub skopiuj i wklej ten link w przegladarke:"

msgid "Your account has not been activated yet. Please check your email for the activation link."
msgstr "Twoje konto nie zostalo jeszcze aktywowane. Sprawdz swoj email w poszukiwaniu linku aktywacyjnego."

msgid "Invalid activation link."
msgstr "Nieprawidlowy link aktywacyjny."

msgid "Your account has been activated. You can now log in."
msgstr "Twoje konto zostalo aktywowane. Mozesz sie teraz zalogowac."

# Gateway
msgid "Invoice / Bank Transfer"
msgstr "Przelew bankowy / Faktura"

msgid "Customer pays via bank transfer after receiving an invoice. Order is set to on-hold until payment is received."
msgstr "Klient placi przelewem bankowym po otrzymaniu faktury. Zamowienie jest wstrzymane do momentu otrzymania wplaty."

msgid "Bank Transfer (Przelew)"
msgstr "Przelew bankowy"

msgid "Pay via bank transfer. Your order will be processed after we receive payment."
msgstr "Zaplac przelewem bankowym. Twoje zamowienie zostanie zrealizowane po otrzymaniu wplaty."

msgid "Displayed on the thank-you page and in confirmation emails. Include your bank account details here."
msgstr "Wyswietlane na stronie podziekowania i w emailach. Podaj tutaj dane konta bankowego."

msgid "Bank Account Number"
msgstr "Numer konta bankowego"

msgid "Your bank account number (IBAN format recommended)."
msgstr "Numer konta bankowego (zalecany format IBAN)."

msgid "Bank Name"
msgstr "Nazwa banku"

msgid "Name of your bank."
msgstr "Nazwa Twojego banku."

msgid "Awaiting bank transfer payment."
msgstr "Oczekiwanie na przelew bankowy."

msgid "Bank Transfer Details"
msgstr "Dane do przelewu"

msgid "Account number"
msgstr "Numer konta"

msgid "Bank"
msgstr "Bank"

msgid "Transfer title"
msgstr "Tytul przelewu"

