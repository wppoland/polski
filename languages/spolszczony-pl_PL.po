# Admin notes
msgid "Configure Spolszczony for your store"
msgstr "Skonfiguruj Spolszczony dla Twojego sklepu"

msgid "Complete the setup wizard to configure Polish legal compliance for your WooCommerce store. This includes legal pages, checkout settings, and price display options."
msgstr "Ukonczenie kreatora konfiguracji pozwoli dostosowac Twoj sklep WooCommerce do polskich wymagan prawnych. Obejmuje to strony prawne, ustawienia kasy i opcje wyswietlania cen."

msgid "Run Setup Wizard"
msgstr "Uruchom kreator konfiguracji"

# Plugin requirements
msgid "Spolszczony requires PHP %1$s or higher. You are running PHP %2$s."
msgstr "Spolszczony wymaga PHP %1$s lub nowszego. Uzywasz PHP %2$s."

msgid "Spolszczony requires Composer autoloader. Run \"composer install\" in the plugin directory."
msgstr "Spolszczony wymaga autoloadera Composera. Uruchom \"composer install\" w katalogu wtyczki."

msgid "Spolszczony requires WooCommerce to be installed and activated."
msgstr "Spolszczony wymaga zainstalowania i aktywowania WooCommerce."

msgid "Spolszczony requires WooCommerce %1$s or higher. You are running WooCommerce %2$s."
msgstr "Spolszczony wymaga WooCommerce %1$s lub nowszego. Uzywasz WooCommerce %2$s."

