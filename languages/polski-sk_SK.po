#: src/PageCompliance/Rules/AccessibilityRules.php:30
msgid "Document language declared (html lang)"
msgstr "Deklarovaný jazyk dokumentu (html lang)"

#: src/PageCompliance/Rules/AccessibilityRules.php:42
msgid ""
"Add a `lang` attribute to the <html> element (WCAG 3.1.1). WordPress usually"
" emits this via the language_attributes() call."
msgstr ""
"Pridajte atribút `lang` k elementu <html> (WCAG 3.1.1). WordPress ho "
"zvyčajne generuje volaním language_attributes()."

#: src/PageCompliance/Rules/AccessibilityRules.php:46
msgid "Skip-to-content link present"
msgstr "Prítomný odkaz na preskočenie na obsah"

#: src/PageCompliance/Rules/AccessibilityRules.php:55
msgid ""
"Provide a skip-to-content link as the first focusable element (WCAG 2.4.1)."
msgstr ""
"Poskytnite odkaz na preskočenie na obsah ako prvý zameriteľný prvok (WCAG "
"2.4.1)."

#: src/PageCompliance/Rules/AccessibilityRules.php:59
msgid "Primary heading (h1) present"
msgstr "Prítomný hlavný nadpis (h1)"

#: src/PageCompliance/Rules/AccessibilityRules.php:64
msgid ""
"Homepage should expose exactly one <h1> describing the page (WCAG 1.3.1 / "
"2.4.6)."
msgstr ""
"Domovská stránka by mala obsahovať presne jeden <h1> popisujúci stránku "
"(WCAG 1.3.1 / 2.4.6)."

#: src/PageCompliance/Rules/AccessibilityRules.php:68
msgid "Responsive viewport declared"
msgstr "Deklarovaný responzívny viewport"

#: src/PageCompliance/Rules/AccessibilityRules.php:74
msgid ""
"Include <meta name=\"viewport\"> with width=device-width so the page scales "
"on mobile (WCAG 1.4.10 Reflow)."
msgstr ""
"Zahrňte <meta name=\"viewport\"> s width=device-width, aby sa stránka "
"prispôsobila na mobile (WCAG 1.4.10 Reflow)."

#: src/PageCompliance/Rules/AccessibilityRules.php:78
msgid "Search form uses role=\"search\" or <search>"
msgstr "Vyhľadávací formulár používa role=\"search\" alebo <search>"

#: src/PageCompliance/Rules/AccessibilityRules.php:85
msgid ""
"If your header exposes a search form, wrap it in <search> or add "
"role=\"search\" so assistive tech can jump to it."
msgstr ""
"Ak váš header obsahuje vyhľadávací formulár, obaľte ho do <search> alebo "
"pridajte role=\"search\", aby k nemu asistenčné technológie mohli prejsť."

#: src/PageCompliance/Rules/AccessibilityRules.php:89
msgid "Main landmark defined"
msgstr "Definovaná hlavná oblasť (main)"

#: src/PageCompliance/Rules/AccessibilityRules.php:98
msgid ""
"The primary content should be wrapped in <main> or role=\"main\" (WCAG "
"1.3.1)."
msgstr ""
"Hlavný obsah by mal byť obalený v <main> alebo role=\"main\" (WCAG 1.3.1)."

#: src/PageCompliance/Rules/AccessibilityRules.php:102
msgid "Focus outline not suppressed globally"
msgstr "Obrys fokusu nie je globálne potlačený"

#: src/PageCompliance/Rules/AccessibilityRules.php:110
msgid ""
"Global `outline: none` on :focus breaks keyboard visibility (WCAG 2.4.7). "
"Replace with a visible focus-visible ring."
msgstr ""
"Globálne `outline: none` na :focus narúša viditeľnosť pri ovládaní "
"klávesnicou (WCAG 2.4.7). Nahraďte viditeľným prstencom focus-visible."

#: src/PageCompliance/Rules/AccessibilityRules.php:114
msgid "No autoplay video with sound"
msgstr "Žiadne automatické prehrávanie videa so zvukom"

#: src/PageCompliance/Rules/AccessibilityRules.php:120
msgid ""
"Avoid autoplay (WCAG 1.4.2 Audio Control) or ensure the video is muted and "
"stops within 5 seconds."
msgstr ""
"Vyhnite sa automatickému prehrávaniu (WCAG 1.4.2 Audio Control) alebo "
"zaistite, že video je stlmené a zastaví sa do 5 sekúnd."

#: src/PageCompliance/Rules/AccessibilityRules.php:124
msgid "Images missing alt attribute (heuristic)"
msgstr "Obrázky bez atribútu alt (heuristika)"

#: src/PageCompliance/Rules/AccessibilityRules.php:129
msgid ""
"The homepage contains <img> tags that did not have an `alt=` attribute in "
"the sampled markup (WCAG 1.1.1)."
msgstr ""
"Domovská stránka obsahuje značky <img>, ktoré v analyzovanom kóde nemali "
"atribút `alt=` (WCAG 1.1.1)."

#: src/PageCompliance/Rules/CookieBannerRules.php:31
msgid "Cookie banner present in HTML"
msgstr "Banner cookies prítomný v HTML"

#: src/PageCompliance/Rules/CookieBannerRules.php:38
msgid ""
"No cookie-related markup was detected on the homepage. Install a banner or "
"ensure it renders on initial load (not only after client-side JS)."
msgstr ""
"Na domovskej stránke neboli zistené žiadne značky súvisiace s cookies. "
"Nainštalujte banner alebo zaistite, že sa vykreslí pri prvom načítaní "
"(nielen po spustení JS na strane klienta)."

#: src/PageCompliance/Rules/CookieBannerRules.php:42
msgid "Accept button label"
msgstr "Označenie tlačidla Prijať"

#: src/PageCompliance/Rules/CookieBannerRules.php:54
msgid "Expose a clearly labelled Accept / Akceptuje button in the banner."
msgstr "Zobrazte v banneri jasne označené tlačidlo Prijať / Akceptuje."

#: src/PageCompliance/Rules/CookieBannerRules.php:58
msgid "Reject button with equal prominence"
msgstr "Tlačidlo Odmietnuť s rovnakou výraznosťou"

#: src/PageCompliance/Rules/CookieBannerRules.php:71
msgid ""
"Active consent requires an equally visible Reject option next to Accept. A "
"greyed-out or hidden button is not compliant."
msgstr ""
"Aktívny súhlas vyžaduje rovnako viditeľnú možnosť Odmietnuť vedľa Prijať. "
"Sivé alebo skryté tlačidlo nevyhovuje."

#: src/PageCompliance/Rules/CookieBannerRules.php:75
msgid "Granular settings / preferences"
msgstr "Podrobné nastavenia / predvoľby"

#: src/PageCompliance/Rules/CookieBannerRules.php:87
msgid ""
"Provide a Settings / Preferences link so users can consent to individual "
"categories (analytics, marketing) independently."
msgstr ""
"Poskytnite odkaz Nastavenia / Predvoľby, aby používatelia mohli nezávisle "
"udeliť súhlas pre jednotlivé kategórie (analytika, marketing)."

#: src/PageCompliance/Rules/CookieBannerRules.php:91
msgid "Analytics category mentioned"
msgstr "Spomenutá kategória Analytika"

#: src/PageCompliance/Rules/CookieBannerRules.php:100
msgid ""
"Explicitly name the Analytics/Statistics category so the user knows what the"
" toggle covers."
msgstr ""
"Výslovne pomenujte kategóriu Analytika/Štatistiky, aby používateľ vedel, čo "
"prepínač zahŕňa."

#: src/PageCompliance/Rules/CookieBannerRules.php:104
msgid "Marketing / advertising category mentioned"
msgstr "Spomenutá kategória Marketing / reklama"

#: src/PageCompliance/Rules/CookieBannerRules.php:114
msgid ""
"Name the Marketing/Advertising category separately so opt-in is granular."
msgstr ""
"Pomenujte kategóriu Marketing/Reklama samostatne, aby bol súhlas podrobný."

#: src/PageCompliance/Rules/CookieBannerRules.php:118
msgid "Link to privacy policy in banner area"
msgstr "Odkaz na zásady ochrany osobných údajov v oblasti banneru"

#: src/PageCompliance/Rules/CookieBannerRules.php:126
msgid ""
"Link the banner to the full privacy policy so users can read the details "
"before consenting."
msgstr ""
"Prepojte banner s úplnými zásadami ochrany osobných údajov, aby si "
"používatelia mohli prečítať podrobnosti pred udelením súhlasu."

#: src/PageCompliance/Rules/CookieBannerRules.php:130
msgid "Consent withdrawal mechanism hinted"
msgstr "Naznačený mechanizmus odvolania súhlasu"

#: src/PageCompliance/Rules/CookieBannerRules.php:141
msgid ""
"Mention that consent can be withdrawn or changed at any time from the banner"
" or a dedicated link."
msgstr ""
"Uveďte, že súhlas možno kedykoľvek odvolať alebo zmeniť z banneru alebo cez "
"vyhradený odkaz."

#: src/PageCompliance/Rules/CookieBannerRules.php:145
msgid "Banner does not rely on scrolling to imply consent"
msgstr "Banner neodvodzuje súhlas zo samotného posúvania"

#: src/PageCompliance/Rules/CookieBannerRules.php:154
msgid ""
"Phrases like \"By continuing to use the site you agree\" are considered "
"implied consent and fail active-consent rules. Remove them and require an "
"explicit click."
msgstr ""
"Frázy ako \"Pokračovaním v používaní stránky vyjadrujete súhlas\" sa "
"považujú za predpokladaný súhlas a nespĺňajú pravidlá aktívneho súhlasu. "
"Odstráňte ich a vyžadujte výslovné kliknutie."

#: src/PageCompliance/Rules/CookieBannerRules.php:158
msgid "No auto-prompt for push notifications on first load"
msgstr "Žiadne automatické vyžiadanie push notifikácií pri prvom načítaní"

#: src/PageCompliance/Rules/CookieBannerRules.php:170
msgid ""
"Triggering Notification.requestPermission() without prior user interaction "
"is a deceptive pattern (EDPB 03/2022) and is also blocked by modern "
"browsers. Gate push-subscribe prompts behind an explicit user click."
msgstr ""
"Vyvolanie Notification.requestPermission() bez predchádzajúcej interakcie "
"používateľa je klamlivý vzor (EDPB 03/2022) a je tiež blokované modernými "
"prehliadačmi. Vyžiadania prihlásenia na push notifikácie podmieňte výslovným"
" kliknutím používateľa."

#: src/PageCompliance/Rules/PrivacyPolicyRules.php:33
msgid "Controller identity and contact"
msgstr "Totožnosť a kontakt prevádzkovateľa"

#: src/PageCompliance/Rules/PrivacyPolicyRules.php:40
msgid ""
"Add a paragraph identifying the data controller by company name, address and"
" contact details."
msgstr ""
"Pridajte odsek identifikujúci prevádzkovateľa údajov názvom spoločnosti, "
"adresou a kontaktnými údajmi."

#: src/PageCompliance/Rules/PrivacyPolicyRules.php:44
msgid "Contact channel (email or form)"
msgstr "Kontaktný kanál (e-mail alebo formulár)"

#: src/PageCompliance/Rules/PrivacyPolicyRules.php:53
msgid ""
"Provide an email address or a link to a contact form so users can reach the "
"controller about their data."
msgstr ""
"Poskytnite e-mailovú adresu alebo odkaz na kontaktný formulár, aby "
"používatelia mohli kontaktovať prevádzkovateľa ohľadom svojich údajov."

#: src/PageCompliance/Rules/PrivacyPolicyRules.php:57
msgid "Purposes of processing"
msgstr "Účely spracúvania"

#: src/PageCompliance/Rules/PrivacyPolicyRules.php:66
msgid ""
"State why you process personal data (e.g. order fulfilment, marketing, legal"
" obligations)."
msgstr ""
"Uveďte, prečo spracúvate osobné údaje (napr. vybavenie objednávok, "
"marketing, zákonné povinnosti)."

#: src/PageCompliance/Rules/PrivacyPolicyRules.php:70
msgid "Legal basis under RODO Art. 6"
msgstr "Právny základ podľa čl. 6 GDPR"

#: src/PageCompliance/Rules/PrivacyPolicyRules.php:79
msgid ""
"Reference the legal basis (Art. 6(1)(a) consent, (b) contract, (c) legal "
"obligation, (f) legitimate interest)."
msgstr ""
"Uveďte právny základ (čl. 6 ods. 1 písm. a súhlas, b zmluva, c zákonná "
"povinnosť, f oprávnený záujem)."

#: src/PageCompliance/Rules/PrivacyPolicyRules.php:83
msgid "Retention period"
msgstr "Doba uchovávania"

#: src/PageCompliance/Rules/PrivacyPolicyRules.php:92
msgid ""
"Indicate how long personal data will be retained (fixed period or criteria)."
msgstr ""
"Uveďte, ako dlho budú osobné údaje uchovávané (pevná doba alebo kritériá)."

#: src/PageCompliance/Rules/PrivacyPolicyRules.php:96
msgid "Data recipients (processors)"
msgstr "Príjemcovia údajov (sprostredkovatelia)"

#: src/PageCompliance/Rules/PrivacyPolicyRules.php:106
msgid ""
"List categories of recipients (shipping carriers, payment providers, "
"accounting, IT vendors)."
msgstr ""
"Uveďte kategórie príjemcov (prepravcovia, poskytovatelia platieb, "
"účtovníctvo, dodávatelia IT)."

#: src/PageCompliance/Rules/PrivacyPolicyRules.php:110
msgid "Right of access"
msgstr "Právo na prístup"

#: src/PageCompliance/Rules/PrivacyPolicyRules.php:117
msgid "State that users can request access to their personal data."
msgstr ""
"Uveďte, že používatelia môžu požiadať o prístup k svojim osobným údajom."

#: src/PageCompliance/Rules/PrivacyPolicyRules.php:121
msgid "Right to rectification"
msgstr "Právo na opravu"

#: src/PageCompliance/Rules/PrivacyPolicyRules.php:128
msgid "State the right to correct inaccurate personal data."
msgstr "Uveďte právo na opravu nesprávnych osobných údajov."

#: src/PageCompliance/Rules/PrivacyPolicyRules.php:132
msgid "Right to erasure (to be forgotten)"
msgstr "Právo na vymazanie (na zabudnutie)"

#: src/PageCompliance/Rules/PrivacyPolicyRules.php:141
msgid "State the right to request deletion of personal data."
msgstr "Uveďte právo požiadať o vymazanie osobných údajov."

#: src/PageCompliance/Rules/PrivacyPolicyRules.php:145
msgid "Right to restriction of processing"
msgstr "Právo na obmedzenie spracúvania"

#: src/PageCompliance/Rules/PrivacyPolicyRules.php:152
msgid "State the right to restrict processing in specific situations."
msgstr "Uveďte právo na obmedzenie spracúvania v konkrétnych situáciách."

#: src/PageCompliance/Rules/PrivacyPolicyRules.php:156
msgid "Right to data portability"
msgstr "Právo na prenosnosť údajov"

#: src/PageCompliance/Rules/PrivacyPolicyRules.php:163
msgid "State the right to receive data in a structured format."
msgstr "Uveďte právo získať údaje v štruktúrovanom formáte."

#: src/PageCompliance/Rules/PrivacyPolicyRules.php:167
msgid "Right to object"
msgstr "Právo namietať"

#: src/PageCompliance/Rules/PrivacyPolicyRules.php:175
msgid "State the right to object to processing (especially for marketing)."
msgstr ""
"Uveďte právo namietať proti spracúvaniu (najmä na marketingové účely)."

#: src/PageCompliance/Rules/PrivacyPolicyRules.php:179
msgid "Right to withdraw consent"
msgstr "Právo odvolať súhlas"

#: src/PageCompliance/Rules/PrivacyPolicyRules.php:187
msgid ""
"State that consent can be withdrawn at any time where processing is based on"
" consent."
msgstr ""
"Uveďte, že súhlas možno kedykoľvek odvolať, ak je spracúvanie založené na "
"súhlase."

#: src/PageCompliance/Rules/PrivacyPolicyRules.php:191
msgid "Right to lodge complaint with UODO"
msgstr "Právo podať sťažnosť dozornému úradu"

#: src/PageCompliance/Rules/PrivacyPolicyRules.php:200
msgid ""
"Reference the Polish supervisory authority (Prezes UODO) as the complaint "
"recipient."
msgstr "Uveďte dozorný úrad ako adresáta sťažnosti."

#: src/PageCompliance/Rules/PrivacyPolicyRules.php:204
msgid "Automated decision-making / profiling disclosure"
msgstr "Informácia o automatizovanom rozhodovaní / profilovaní"

