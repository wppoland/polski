msgid "Minimum order value (0 = disabled)"
msgstr "Minimálna hodnota objednávky (0 = vypnuté)"

#: src/Admin/ModulesPage.php:1307
msgid "Cart subtotal must reach this amount to proceed to checkout."
msgstr ""
"Medzisúčet košíka musí dosiahnuť túto sumu, aby ste mohli prejsť k pokladni."

