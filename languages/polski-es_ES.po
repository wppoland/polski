msgstr ""
"Configura <a href=\"%s\">tasas de IVA</a> en WooCommerce para el mercado "
"polaco, 23%%, 8%%, 5%% y 0%%."

#. translators: %s is the WooCommerce shipping zones URL.
#: config/defaults.php:48
#, php-format
msgid "Skonfiguruj <a href=\"%s\">strefy wysyłki</a> dla dostaw w Polsce."
msgstr "Configure <a href=\"%s\">zonas de envío</a> para entregas en Polonia."

#. translators: %s is the WooCommerce product edit URL for Polski product
#. data.
#: config/defaults.php:50
#, php-format
msgid ""
"Uzupełnij dane produktów, dodaj ceny jednostkowe i czasy dostawy w <a "
"href=\"%s\">zakładce Polski</a> dla każdego produktu."
msgstr ""
"Completa los datos del producto, añade precios unitarios y plazos de entrega"
" en la <a href=\"%s\">pestaña Polonia</a> de cada producto."

