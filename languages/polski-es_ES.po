msgstr "Cuánto tiempo permanece visible cada notificación. Recomendado: 4-6"

#: src/Admin/ModulesPage.php:1457
msgid "Anonymize customer names"
msgstr "Anonimizar los nombres de los clientes"

#: src/Admin/ModulesPage.php:1457
msgid "Shows \"J. from Warszawa\" instead of full names. Recommended for GDPR"
msgstr ""
"Muestra \"J. de Warszawa\" en lugar de nombres completos. Recomendado para "
"GDPR"

