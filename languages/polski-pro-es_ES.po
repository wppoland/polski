"Twoją opinię."
msgstr ""
"Hola {first_name}, gracias por tus compras recientes. Agradeceríamos su "
"opinión."

#: config/defaults.php:89
msgid "Zostaw opinię"
msgstr "Deja una reseña"

#: config/defaults.php:90
msgid "Zrezygnuj z próśb o opinię"
msgstr "No recibir más solicitudes de opinión"

#: config/defaults.php:91
msgid "Nie będziemy już wysyłać próśb o opinię."
msgstr "Ya no enviaremos solicitudes de comentarios."

#: config/defaults.php:99
msgid ""
"Minimalna wartość zamówienia to {min_value}. Aktualna wartość koszyka: "
"{current_value}."
msgstr ""
"El valor mínimo del pedido es {min_value}. Valor actual de la cesta: "
"{current_value}."

#: config/defaults.php:100
msgid ""
"Minimalna liczba produktów w zamówieniu to {min_quantity}. Aktualna liczba: "
"{current_quantity}."
msgstr ""
"La cantidad mínima de productos en un pedido es {min_quantity}. Cantidad "
"actual: {current_quantity}."

