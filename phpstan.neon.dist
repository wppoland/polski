includes:
    - vendor/szepeviktor/phpstan-wordpress/extension.neon
    - phpstan-baseline.neon

parameters:
    treatPhpDocTypesAsCertain: false
    level: 8
    paths:
        - src/
    excludePaths:
        - vendor/
    bootstrapFiles:
        - vendor/autoload.php
        - tests/phpstan/polski-plugin-constants.php
        - tests/phpstan/wp-path-constants.php
        - vendor/php-stubs/woocommerce-stubs/woocommerce-stubs.php
        - tests/phpstan/elementor-phpstan-stubs.php
        - tests/phpstan/wp-cli-phpstan-stubs.php
        - tests/phpstan/ai-client-phpstan-stubs.php
        # Store API (Blocks) classes are not in php-stubs/woocommerce-stubs; the file
        # guards each declaration with class_exists so it only defines them when missing
        # (CI/stubs-only) and stays inert when a local vendor has full WooCommerce.
        - tests/phpstan/woocommerce-store-api-stubs.php
    # Don't fail if a global ignoreErrors pattern no longer matches anything —
    # the per-file baseline below already captures every legacy error precisely.
    reportUnmatchedIgnoredErrors: false
    ignoreErrors:
        # Table names use $wpdb->prefix; SQL template is not a PHP literal-string.
        -
            message: '~Parameter #1 \$query of method wpdb::prepare\(\) expects literal-string~'
        -
            message: '~Parameter #1 \$query of method wpdb::query\(\) expects string, string\|null given~'
