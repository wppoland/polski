#. Found in description list item.
msgid ""
"<strong>Storefront</strong>: wishlist, comparison, search, filters and "
"badges."
msgstr ""
"<strong>Front sklepu</strong>: lista życzeń, porównywarka, wyszukiwarka, "
"filtry i odznaki."

#. Found in description list item.
msgid ""
"<strong>REST API</strong> - an API for settings, checkboxes, legal pages, "
"withdrawals and search."
msgstr ""
"<strong>REST API</strong> - API dla ustawień, checkboxów, stron prawnych, "
"odstąpień i wyszukiwania."

#. Found in description list item.
msgid ""
"<strong>Product badges</strong> - sale, new, featured and custom labels."
msgstr ""
"<strong>Odznaki produktów</strong> - oznaczenia promocji, nowości, wyróżnień"
" i własnych etykiet."

#. Found in description list item.
msgid "<strong>AJAX search</strong> - live product search."
msgstr "<strong>Wyszukiwarka AJAX</strong> - wyszukiwanie produktów na żywo."

#. Found in description list item.
msgid "<strong>Gallery zoom</strong> - enhanced product image zoom."
msgstr ""
"<strong>Powiększenie galerii</strong> - rozszerzone powiększanie zdjęć "
"produktu."

#. Found in description list item.
msgid "<strong>Wishlist</strong> - save products for later."
msgstr "<strong>Lista życzeń</strong> - zapisywanie produktów na później."

#. Found in description list item.
msgid ""
"<strong>Delivery time</strong> - estimated delivery time on product pages "
"and product lists."
msgstr ""
"<strong>Czas dostawy</strong> - informacja o przewidywanym czasie dostawy na"
" stronach produktów i listach produktów."

#. Found in description list item.
msgid ""
"<strong>Unit prices</strong> - price per kg, litre, metre, piece or a custom"
" unit."
msgstr ""
"<strong>Ceny jednostkowe</strong> - cena za kg, litr, metr, sztukę albo "
"własną jednostkę."

#. Found in description list item.
msgid ""
"<strong>GPSR product fields</strong> - manufacturer, importer, EU "
"responsible person, product identifiers, safety warnings and instructions, "
"including CSV import and export."
msgstr ""
"<strong>Pola GPSR produktu</strong> - producent, importer, osoba "
"odpowiedzialna w UE, identyfikatory produktu, ostrzeżenia i instrukcje "
"bezpieczeństwa, także z importem i eksportem CSV."

#. Found in description list item.
msgid ""
"<strong>HPOS compatible</strong> - supports WooCommerce High-Performance "
"Order Storage."
msgstr ""
"<strong>Zgodność z HPOS</strong> - wsparcie WooCommerce High-Performance "
"Order Storage."

#. Found in description list item.
msgid ""
"<strong>Modern code</strong> - PHP 8.1+, a React admin panel, REST API and "
"WP-CLI support."
msgstr ""
"<strong>Nowoczesny kod</strong> - PHP 8.1+, panel administracyjny React, "
"REST API i wsparcie WP-CLI."

#. Found in description header.
msgid "Google Tag Manager / Google Analytics"
msgstr "Google Tag Manager / Google Analytics"

