msgid ""
"Terms of service: <a "
"href=\"https://api.stat.gov.pl/Home/RegulaminBIR\">https://api.stat.gov.pl/Home/RegulaminBIR</a>"
msgstr ""
"Términos de servicio: <a "
"href=\"https://api.stat.gov.pl/Home/RegulaminBIR\">https://api.stat.gov.pl/Home/RegulaminBIR</a>"

#. Found in description list item.
