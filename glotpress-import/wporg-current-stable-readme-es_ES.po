#. Short description.
#, gp-priority: high
msgid ""
"WooCommerce for Polish shops: GPSR, Omnibus, GDPR, withdrawals, VAT ID, "
"KSeF, unit prices and storefront modules."
msgstr ""
"WooCommerce para tiendas polacas: GPSR, Omnibus, GDPR, retiros, VAT ID, "
"KSeF, precios unitarios y módulos de escaparate."

#. Plugin name.
#, gp-priority: high
msgid "Polski for WooCommerce"
msgstr "Polski for WooCommerce"

#. Found in description paragraph.
msgid ""
"Compare editions and pricing: <a href=\"https://plogins.com/polski-"
"pro/pricing/\">plogins.com/polski-pro/pricing/</a>"
msgstr ""
"Compara ediciones y precios: <a href=\"https://plogins.com/polski-"
"pro/pricing/\">plogins.com/polski-pro/pricing/</a>"

