{
  "name": "@wppoland/polski",
  "version": "1.10.0",
  "description": "Product information, checkout, consent, and storefront tools for WooCommerce stores in Poland",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "node scripts/build-wp.mjs && wp-scripts build --webpack-src-dir=resources/js/blocks --output-path=build/blocks",
    "build:admin": "node scripts/build-wp.mjs",
    "build:blocks": "wp-scripts build --webpack-src-dir=resources/js/blocks --output-path=build/blocks",
    "lint:js": "wp-scripts lint-js resources/js",
    "lint:css": "wp-scripts lint-style resources/css",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "env:start": "wp-env start",
    "env:stop": "wp-env stop",
    "env:clean": "wp-env clean all",
    "env:cli": "wp-env run cli",
    "check:wporg": "bash scripts/plugin-check.sh",
    "check:wporg:free": "bash scripts/plugin-check.sh polski",
    "check:wporg:pro": "bash scripts/plugin-check.sh polski-pro",
    "i18n:pot": "wp i18n make-pot . languages/polski.pot --exclude=node_modules,vendor,_benchmark,build,tests --domain=polski",
    "i18n:mo": "wp i18n make-mo languages/",
    "i18n:json": "wp i18n make-json languages/",
    "i18n:compile": "npm run i18n:mo && npm run i18n:json",
    "test:a11y": "playwright test withdrawal-a11y --project=chromium",
    "test:screenshots": "playwright test withdrawal-screenshots --project=chromium",
    "test:lhci": "lhci autorun --config=./lighthouserc.json"
  },
  "devDependencies": {
    "@playwright/test": "^1.48",
    "@types/react": "^18.3",
    "@types/react-dom": "^18.3",
    "@wordpress/block-editor": "^14.0",
    "@wordpress/blocks": "^13.0",
    "@wordpress/components": "^28.0",
    "@wordpress/data": "^10.0",
    "@wordpress/element": "^6.0",
    "@wordpress/i18n": "^5.0",
    "@wordpress/scripts": "^30.0",
    "@wordpress/env": "^10.0",
    "react": "^18.3",
    "react-dom": "^18.3",
    "react-router-dom": "^7.0",
    "typescript": "^5.6",
    "vite": "^6.0"
  }
}
